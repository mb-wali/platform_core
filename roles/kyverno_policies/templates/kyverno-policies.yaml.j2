# https://github.com/kyverno/kyverno/blob/main/charts/kyverno-policies/values.yaml
# https://artifacthub.io/packages/helm/kyverno/kyverno-policies

# -- Pod Security Standard profile (`baseline`, `restricted`, `privileged`, `custom`).
# For more info https://kyverno.io/policies/pod-security.
podSecurityStandard: {{ kyverno_podSecurityStandard }}

# -- Validation failure action (`Audit`, `Enforce`).
# For more info https://kyverno.io/docs/policy-types/cluster-policy/validate.
validationFailureAction: {{ kyverno_validationFailureAction }}

# TODO: try disabling this and see what is not working...
validationFailureActionOverrides:
  all:
    - action: audit
      namespaceSelector:
        matchLabels:
          policy.kyverno.io/audit: "true"
    - action: audit
      namespaces:
        - kube-system
        - cert-manager
        - nfs-provisioner
        - ceph-csi-rbd
        - ceph-csi-cephfs
        - monitoring # kube-prometheus-stack
        - cattle-system # rancher
        - cattle-fleet-system # rancher
        - cattle-capi-system # rancher
        - cattle-impersonation-system # rancher
        - cattle-local-user-passwords # rancher
        - cattle-turtles-system # rancher
        - cattle-ui-plugin-system # rancher
        - cattle-global-data # rancher
        - fleet-local # rancher
        - fleet-default # rancher
        - cattle-fleet-clusters-system # rancher
        - cattle-fleet-local-system # rancher
        
  disallow-capabilities-strict:
    - action: audit
      namespaces:
        - vault
        - argocd
  restrict-seccomp-strict:
    - action: audit
      namespaces:
        - vault
        - argocd
        - gitlab-runner
  disallow-privilege-escalation:
    - action: audit
      namespaces:
        - argocd
  require-run-as-nonroot:
    - action: audit
      namespaces:
        - argocd
