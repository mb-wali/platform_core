# https://github.com/cilium/cilium/tree/main/install/kubernetes/cilium

ingressController:
  enabled: {{ cilium_ingress_controller_enable | lower }}
  default: false
  loadbalancerMode: shared
  enforceHttps: false # This will let cilium ingress controller route entries without ingress class set
  enableProxyProtocol: false
  service:
    name: cilium-ingress
    type: NodePort
    insecureNodePort: {{ cilium_ingress_controller_node_port_http }}
    secureNodePort: {{ cilium_ingress_controller_node_port_https }}
    externalTrafficPolicy: Local

cni:
  install: true
  chainingMode: none
  confPath: /etc/cni/net.d
  binPath: /opt/cni/bin

# Configure the kube-proxy replacement in Cilium BPF datapath
# Valid options: "true", "false", "partial", "strict"
kubeProxyReplacement: "{{ cilium_kubeproxy_replacement }}"

hubble:
  ui:
    enabled: {{ cilium_hubble_ui_enabled | lower }}
    ingress:
      enabled: {{ cilium_hubble_ui_ingress_enabled | lower }}
      className: "{{ cilium_ingress_class }}"
      ingressClassName: "{{ cilium_ingress_class }}"
      annotations:
        nginx.ingress.kubernetes.io/rewrite-target: /
        nginx.ingress.kubernetes.io/ssl-redirect: "false"
      hosts:
        - "{{ cilium_ingress_host }}"
      path: /
      pathType: Prefix
      tls: []  # TLS handled externally

  relay:
    enabled: false # true  # does not work with kyverno

debug:
  enabled: {{ cilium_debug_enabled | lower }}
  verbose: "{{ cilium_debug_verbose }}"



ipam:
  operator:
    # k8s=10.0.0.0/8 / k3s=10.42.0.0/16
    clusterPoolIPv4PodCIDRList: ["{{ cilium_clusterPoolIPv4PodCIDRList }}"] 

operator:
  # -- Enable the cilium-operator component (required).
  enabled: true
  # atleast 2 for prod and 1 for k3s singlenode
  replicas: {{ cilium_operator_replicas }}


# -- The agent can be put into one of the three policy enforcement modes:
# default, always and never.
# ref: https://docs.cilium.io/en/stable/security/policy/intro/#policy-enforcement-modes
policyEnforcementMode: "{{ cilium_enforce_mode }}"
